# Secure Agent Browser Security Suite - Configuration

# 1. VirusTotal API Key
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# 2. OpenAI API Key (Required for Agent Logic)
OPENAI_API_KEY=your_openai_api_key_here

# 3. Browser Use API Key (Required for Browser Automation)
